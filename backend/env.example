# ============================================
# CiviX Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ============================================
# Server Configuration
# ============================================
PORT=8080
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/civix

# ============================================
# Supabase Storage Configuration
# ============================================
# Required for file uploads to buckets:
# - complaint-images (for complaint photos)
# - complaint-audio (for complaint audio recordings)
# - resolution-images (for resolution photos)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# Authentication & Security
# ============================================
# JWT Secret - Generate a strong random string for production
# Run: npm run generate-jwt
JWT_SECRET=your-secret-key-change-in-production-min-32-characters

# ============================================
# Google Cloud Platform Configuration
# ============================================
# Required for: Speech-to-Text API, Translation API
# 
# Option 1: Using service account JSON file path
GOOGLE_STT_KEY=./config/gcp-service-account-key.json
GOOGLE_PROJECT_ID=your-gcp-project-id

# Option 2: Using direct credentials (alternative)
# GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_PROJECT_ID=your-gcp-project-id

# ============================================
# Google Gemini API Configuration
# ============================================
# Required for: AI-powered department classification
# Get from: https://makersuite.google.com/app/apikey
GEMINI_KEY=your-gemini-api-key-here

# ============================================
# Optional Configuration
# ============================================
# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File upload limits
# MAX_FILE_SIZE_MB=10
# MAX_AUDIO_DURATION_SECONDS=60
